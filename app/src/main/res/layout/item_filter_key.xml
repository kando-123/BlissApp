<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="8dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/keyboard_key_background"
        app:strokeWidth="1dp"
        app:strokeColor="@color/settings_divider">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/filter_key_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="@null"
                tools:src="@drawable/radical_heart" />

            <TextView
                android:id="@+id/filter_key_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="A"
                tools:visibility="visible" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/filter_key_counter"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-6dp"
        android:layout_marginRight="-6dp"
        android:background="@drawable/indicator_key_background"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="10sp"
        android:textStyle="bold"
        android:elevation="6dp"
        android:visibility="gone"
        tools:text="3"
        tools:visibility="visible" />

</FrameLayout>