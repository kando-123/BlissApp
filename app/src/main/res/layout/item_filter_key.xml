<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/filter_key_image"
        android:layout_width="@dimen/filter_bar_height"
        android:layout_height="@dimen/filter_bar_height"
        android:layout_gravity="center"
        android:background="@drawable/key_background"
        android:contentDescription="@null"
        android:padding="8dp"
        android:scaleType="fitCenter"
        tools:src="@drawable/radical_heart" />

    <TextView
        android:id="@+id/filter_key_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:background="@drawable/key_background"
        android:paddingLeft="4dp"
        android:paddingRight="4dp"
        android:textColor="@color/black"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="x3"
        tools:visibility="visible" />

</FrameLayout>