<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.BlissApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/lavender_primary</item>
        <item name="colorPrimaryVariant">@color/lavender_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Background/Surface colors -->
        <item name="android:windowBackground">@color/lavender_surface</item>
        <item name="colorSurface">@color/white</item>
    </style>

    <style name="Theme.BlissApp.Lavender" parent="Theme.BlissApp">
        <item name="colorPrimary">@color/lavender_primary</item>
        <item name="colorPrimaryVariant">@color/lavender_variant</item>
        <item name="android:windowBackground">@color/lavender_surface</item>
    </style>

    <style name="Theme.BlissApp.Ocean" parent="Theme.BlissApp">
        <item name="colorPrimary">@color/ocean_primary</item>
        <item name="colorPrimaryVariant">@color/ocean_variant</item>
        <item name="android:windowBackground">@color/ocean_surface</item>
    </style>

    <style name="Theme.BlissApp.Forest" parent="Theme.BlissApp">
        <item name="colorPrimary">@color/forest_primary</item>
        <item name="colorPrimaryVariant">@color/forest_variant</item>
        <item name="android:windowBackground">@color/forest_surface</item>
    </style>

    <style name="Theme.BlissApp.Sunset" parent="Theme.BlissApp">
        <item name="colorPrimary">@color/sunset_primary</item>
        <item name="colorPrimaryVariant">@color/sunset_variant</item>
        <item name="android:windowBackground">@color/sunset_surface</item>
    </style>

    <style name="Theme.BlissApp.NoActionBar" parent="Theme.BlissApp">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.BlissApp.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.BlissApp.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="ShapeAppearanceOverlay.BlissApp.Rounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
</resources>