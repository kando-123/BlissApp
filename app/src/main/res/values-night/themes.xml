<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Shared logic and common attributes) -->
    <style name="Theme.BlissApp.Base" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Background/Surface colors - Dark Mode Default -->
        <item name="android:windowBackground">@color/black</item>
        <item name="colorSurface">@color/black</item>
        <item name="colorOnSurface">@color/white</item>

        <!-- Common flags (inherited by all) -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Modern Splash Screen Theme -->
    <style name="Theme.BlissApp.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_combined</item>
        <item name="postSplashScreenTheme">@style/Theme.BlissApp.Lavender</item>
    </style>

    <!-- Specific Color Themes -->
    <style name="Theme.BlissApp.Lavender" parent="Theme.BlissApp.Base">
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
    </style>

    <style name="Theme.BlissApp.Ocean" parent="Theme.BlissApp.Base">
        <item name="colorPrimary">@color/ocean_primary</item>
        <item name="colorPrimaryVariant">@color/ocean_variant</item>
        <item name="colorOnPrimary">@color/black</item>
    </style>

    <style name="Theme.BlissApp.Forest" parent="Theme.BlissApp.Base">
        <item name="colorPrimary">@color/forest_primary</item>
        <item name="colorPrimaryVariant">@color/forest_variant</item>
        <item name="colorOnPrimary">@color/black</item>
    </style>

    <style name="Theme.BlissApp.Sunset" parent="Theme.BlissApp.Base">
        <item name="colorPrimary">@color/sunset_primary</item>
        <item name="colorPrimaryVariant">@color/sunset_variant</item>
        <item name="colorOnPrimary">@color/black</item>
    </style>

    <!-- Default Theme for the application -->
    <style name="Theme.BlissApp" parent="Theme.BlissApp.Starting" />
</resources>