<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for night mode -->
    <style name="Theme.BlissApp.Base" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#121212</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>

    <style name="Theme.BlissApp.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#121212</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_combined</item>
        <item name="postSplashScreenTheme">@style/Theme.BlissApp.Base</item>
    </style>

    <style name="Theme.BlissApp.Lavender" parent="Theme.BlissApp.Base">
        <item name="colorPrimary">@color/lavender_primary_dark</item>
        <item name="colorPrimaryVariant">@color/lavender_variant_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.BlissApp.Ocean" parent="Theme.BlissApp.Base">
        <item name="colorPrimary">@color/ocean_primary_dark</item>
        <item name="colorPrimaryVariant">@color/ocean_variant_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.BlissApp.Forest" parent="Theme.BlissApp.Base">
        <item name="colorPrimary">@color/forest_primary_dark</item>
        <item name="colorPrimaryVariant">@color/forest_variant_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.BlissApp.Sunset" parent="Theme.BlissApp.Base">
        <item name="colorPrimary">@color/sunset_primary_dark</item>
        <item name="colorPrimaryVariant">@color/sunset_variant_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.BlissApp" parent="Theme.BlissApp.Starting" />

    <!-- Additional styles used in layouts -->
    <style name="Theme.BlissApp.PopupOverlay" parent="ThemeOverlay.AppCompat.Dark" />

    <style name="ShapeAppearanceOverlay.BlissApp.Rounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
</resources>