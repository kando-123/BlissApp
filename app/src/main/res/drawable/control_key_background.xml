<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active state (Shift ON): Distinguished by a subtle border -->
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/keyboard_control_key_ON_background" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/keyboard_key_pressed_background" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <!-- Normal state: Same color as standard keys -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/keyboard_control_key_background" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</selector>